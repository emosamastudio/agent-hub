{
  "name": "@agent-hub/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "regression:gemini": "tsx src/scripts/gemini-runtime-regression.ts",
    "regression:openclaw": "tsx src/scripts/openclaw-runtime-regression.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@agent-hub/shared": "0.1.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^12.4.1",
    "fastify": "^5.6.2",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  }
}
