{
  "name": "@agent-hub/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "regression:gemini": "tsx src/scripts/gemini-runtime-regression.ts",
    "regression:openclaw": "tsx src/scripts/openclaw-runtime-regression.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@agent-hub/shared": "0.1.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/websocket": "^11.2.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.2",
    "pg": "^8.21.0",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.6"
  }
}
