[Unit]
Description=Agent Hub control plane
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=agent-hub
Group=agent-hub
WorkingDirectory=/opt/agent-hub
EnvironmentFile=/etc/agent-hub/agent-hub.env
ExecStart=/usr/bin/node /opt/agent-hub/apps/server/dist/index.js
Restart=always
RestartSec=5
TimeoutStopSec=30
KillSignal=SIGTERM
LimitNOFILE=65536
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/agent-hub /var/log/agent-hub

[Install]
WantedBy=multi-user.target
