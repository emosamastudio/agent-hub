NODE_ENV=production

# PostgreSQL
# Used by deploy/docker-compose.production.yml to initialize the bundled PostgreSQL container.
AGENT_HUB_POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgres://agent_hub:replace-me@127.0.0.1:5432/agent_hub
# Optional restore drill target. Must point at a disposable database, not production.
# AGENT_HUB_RESTORE_DATABASE_URL=postgres://agent_hub:replace-me@127.0.0.1:5432/agent_hub_restore

# HTTP API
AGENT_HUB_HOST=0.0.0.0
AGENT_HUB_PORT=8788

# Dashboard/CLI control-plane auth. Replace before first start.
AGENT_HUB_DASHBOARD_USER=admin
AGENT_HUB_DASHBOARD_PASSWORD=replace-me

# Do not use the development default key in production.
# Project API keys should normally be created through:
# agent-hub projects ensure <project-name>
AGENT_HUB_DEFAULT_API_KEY=replace-me-or-disable-default-project-access

# Production does not seed demo/default data unless explicitly enabled.
AGENT_HUB_BOOTSTRAP_DEFAULT_PROJECT=false
AGENT_HUB_SEED_DEMO_AGENT=false

# Scheduler and retention
AGENT_HUB_SCHEDULER_TICK_MS=1000
AGENT_HUB_EXECUTION_RETENTION_DAYS=90
AGENT_HUB_TRACE_RETENTION_DAYS=30
AGENT_HUB_ALERT_RETENTION_DAYS=180
AGENT_HUB_MAX_TRIGGER_DEPTH=5
